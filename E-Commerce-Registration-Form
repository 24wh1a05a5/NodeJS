<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Registration Form - M.Prasanna</title>
  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body {
      font-family: 'Segoe UI', Arial, sans-serif;
      background: linear-gradient(to right, #fff4e5, #ffd8a8); /* soft pastel orange */
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 10px;
    }
    .container {
      max-width: 800px;
      background-color: #fff;
      padding: 20px 25px;
      border-radius: 12px;
      box-shadow: 0 8px 20px rgba(0,0,0,0.15);
    }
    h2 {
      text-align: center;
      color: #ff914d;
      margin-bottom: 5px;
      font-weight: bold;
    }
    .name-roll {
      text-align: center;
      font-size: 1rem;
      color: #555;
      margin-bottom: 20px;
    }
    .form-label {
      font-weight: 500;
      font-size: 0.9rem;
    }
    .btn-register {
      background-color: #ffcc99; /* pale/light orange */
      border: none;
      color: #333;
      font-weight: bold;
    }
    .btn-register:hover {
      background-color: #ffb366;
      color: #fff;
    }
    .footer {
      text-align: center;
      margin-top: 10px;
      font-size: 0.85rem;
      color: #555;
    }
    /* Two-column layout for desktop */
    @media (min-width: 768px) {
      .row > .col-half {
        flex: 0 0 50%;
        max-width: 50%;
        padding-right: 10px;
      }
      .row > .col-half:last-child {
        padding-right: 0;
      }
    }
  </style>
</head>
<body>

<div class="container">
  <h2>Registration Form</h2>
  <p class="name-roll"><strong>M.Prasanna</strong> | Roll No: 24WH1A05A5</p>

  <form>
    <div class="row">
      <div class="col-12 col-md-6 col-half mb-2">
        <label for="firstName" class="form-label">First Name</label>
        <input type="text" class="form-control form-control-sm" id="firstName" placeholder="First Name" required>
      </div>
      <div class="col-12 col-md-6 col-half mb-2">
        <label for="fullName" class="form-label">Full Name</label>
        <input type="text" class="form-control form-control-sm" id="fullName" placeholder="Full Name" required>
      </div>
    </div>

    <div class="row">
      <div class="col-12 col-md-6 col-half mb-2">
        <label for="contact" class="form-label">Contact Number</label>
        <input type="tel" class="form-control form-control-sm" id="contact" placeholder="Contact No" required>
      </div>
      <div class="col-12 col-md-6 col-half mb-2">
        <label for="age" class="form-label">Age</label>
        <input type="number" class="form-control form-control-sm" id="age" placeholder="Age" required>
      </div>
    </div>

    <div class="row">
      <div class="col-12 col-md-6 col-half mb-2">
        <label class="form-label">Gender</label>
        <div>
          <div class="form-check form-check-inline">
            <input class="form-check-input" type="radio" name="gender" id="male" value="male" required>
            <label class="form-check-label" for="male">Male</label>
          </div>
          <div class="form-check form-check-inline">
            <input class="form-check-input" type="radio" name="gender" id="female" value="female" required>
            <label class="form-check-label" for="female">Female</label>
          </div>
        </div>
      </div>
      <div class="col-12 col-md-6 col-half mb-2">
        <label for="dob" class="form-label">Date of Birth</label>
        <input type="date" class="form-control form-control-sm" id="dob" required>
      </div>
    </div>

    <div class="row">
      <div class="col-12 col-md-6 col-half mb-2">
        <label for="email" class="form-label">Email</label>
        <input type="email" class="form-control form-control-sm" id="email" placeholder="Email" required>
      </div>
      <div class="col-12 col-md-6 col-half mb-2">
        <label for="country" class="form-label">Country</label>
        <select class="form-select form-select-sm" id="country" required>
          <option value="">Select Country</option>
          <option value="india">India</option>
          <option value="usa">USA</option>
          <option value="uk">UK</option>
          <option value="other">Other</option>
        </select>
      </div>
    </div>

    <div class="row">
      <div class="col-12 mb-2">
        <label for="password" class="form-label">Password</label>
        <input type="password" class="form-control form-control-sm" id="password" placeholder="Password" required>
      </div>
    </div>

    <div class="row">
      <div class="col-12 mb-2">
        <label for="address" class="form-label">Address</label>
        <textarea class="form-control form-control-sm" id="address" rows="2" placeholder="Address"></textarea>
      </div>
    </div>

    <!-- Register Button -->
    <div class="d-grid mt-2">
      <button type="submit" class="btn btn-register btn-lg">Register</button>
    </div>
  </form>

  <div class="footer">
    &copy; 2026 M.Prasanna | Roll No: 24WH1A05A5
  </div>
</div>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.1/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
